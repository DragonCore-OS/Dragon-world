{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dragon-system.local/specs/provider_schema.json",
  "title": "Dragon-system Provider Schema",
  "description": "Schema for LLM provider configuration",
  "version": "0.1.0",
  "type": "object",
  "required": ["provider_name", "api_base", "chat_model"],
  "properties": {
    "provider_name": {
      "type": "string",
      "enum": ["kimi", "openai", "anthropic"]
    },
    "api_base": {
      "type": "string",
      "format": "uri"
    },
    "api_key_env": {
      "type": "string",
      "default": "KIMI_API_KEY"
    },
    "chat_model": {
      "type": "string"
    },
    "embedding_model": {
      "type": ["string", "null"]
    },
    "reranker_model": {
      "type": ["string", "null"]
    },
    "timeout_seconds": {
      "type": "integer",
      "default": 60
    },
    "max_retries": {
      "type": "integer",
      "default": 3
    },
    "rate_limit_rpm": {
      "type": "integer"
    },
    "budget": {
      "type": "object",
      "properties": {
        "daily_usd_limit": { "type": "number" },
        "alert_threshold": { "type": "number" }
      }
    }
  }
}
